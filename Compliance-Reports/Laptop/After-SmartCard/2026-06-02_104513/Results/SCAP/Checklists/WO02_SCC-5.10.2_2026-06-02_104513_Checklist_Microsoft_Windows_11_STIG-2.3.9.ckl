					<ATTRIBUTE_DATA></ATTRIBUTE_DATA>
				</STIG_DATA>
				<STIG_DATA>
					<VULN_ATTRIBUTE>Fix_Text</VULN_ATTRIBUTE>
					<ATTRIBUTE_DATA>Create separate accounts for backup operations for users with this privilege.</ATTRIBUTE_DATA>
				</STIG_DATA>
