# Ignore compiled cryptographic keys and certs
*.pfx
*.p12
*.cer
*.crt
*.der
*.pem
*.csr
*.key

# Ignore local hypervisor virtual machine footprints
*.vmdk
*.ova
*.ovf
*.vmem
*.vmsd

# Ignore local editor configuration caches and logs
.vscode/
.idea/
*.log
*.bak

# Ignore OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# Ignore temp / swap files
*.tmp
*.swp
*~

# Local scrub patterns (never commit real values)
.scrub-patterns.local.json
