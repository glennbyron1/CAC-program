# =========================
#  CRYPTO / CERT MATERIAL (CRITICAL)
# =========================
*.pfx
*.p12
*.cer
*.crt
*.der
*.pem
*.csr
*.key

# =========================
#  PKI / CERTIFICATE SERVICE FILES
# =========================
# Certificate database and logs
*.edb
*.jrs
CertLog/

# =========================
#  BACKUPS / SYSTEM IMAGES
# =========================
*.bak
*.backup
*.wbk
*.vhdx

# =========================
#  VIRTUAL MACHINE FILES & INSTALL MEDIA
# =========================
*.vmdk
*.ova
*.ovf
*.vmem
*.vmsd
# OS install media — multi-GB, never belongs in git (e.g. the lab Server 2025 ISO)
*.iso
*.img
Lab-Kit/Server 2025 Standard.iso

# =========================
#  IDE & PROJECT FILES
# =========================
/shelf/
/workspace.xml
/httpRequests/
/dataSources/
/dataSources.local.xml

.vscode/
.idea/

# =========================
#  LOGS / TEMP FILES
# =========================
*.log
*.tmp
*.swp
*~

# =========================
# 🖥 OS JUNK FILES
# =========================
.DS_Store
Thumbs.db
desktop.ini

# =========================
#  LOCAL SENSITIVE CONFIG
# =========================
.scrub-patterns.local.json
ConsoleHost_history.txt
.idea/CAC-Program-ToDo.md

# =========================
#  LOCAL BACKUP SNAPSHOTS
# =========================
# Timestamped full-repo snapshots created by local backup/scrub tooling.
# These should never be committed: they double the repo and can re-introduce
# IDE/workspace files that were intentionally excluded.
archive/
*-TransferKit/
OfflineCA-TransferKit/
CAC-Staging/

# =========================
#  CONVERSATION LOGS / EXPORTS (NEVER COMMIT)
# =========================
# AI session exports and transcripts contain internal narration, absolute
# paths with your username, and the real-identifier scrub list. They are the
# decoder ring for every placeholder in the repo. Keep them out entirely.
Conversation-Export-*.md
*-Conversation-Export.md
*transcript*.md
*.jsonl

# =========================
#  DISPATCH — LOCAL STAGING ONLY (NEVER COMMIT)
# =========================
# Dispatch/ is a local-only staging and review folder. It holds draft files,
# private gap analyses (Agency), and work-in-progress content that is not
# ready or appropriate for the public repo. Nothing in this folder should
# ever be committed or pushed.
Dispatch/

# History-scrub source-of-truth scripts (contain real patterns)
scrub_history.ps1
Run-HistoryScrub.ps1

# History-scrub source-of-truth scripts (contain real patterns)
scrub_history.ps1
Run-HistoryScrub.ps1

# Local-only sensitive-pattern scanner (reads .scrub-patterns.local.json,
# never published - keeps the scrub workflow private)
security/scripts/Scan-LocalRepo.ps1
security/scripts/SCAN-README.md

# Cert-scan CSV output from Check-SelfSignedCerts.ps1 — may contain internal
# subjects/thumbprints. The script defaults output to $env:TEMP; this rule is
# a belt-and-suspenders catch if -OutputPath is pointed at the repo.
security/scripts/cert-scan-*.csv
**/cert-scan-*.csv
