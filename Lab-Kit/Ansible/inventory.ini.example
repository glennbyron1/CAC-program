# Ansible Inventory — CAC/PIV Lab
# Copy this file to inventory.ini and fill in your real IPs and credentials.
# inventory.ini is gitignored — never commit real credentials.
#
# Default lab IP plan (see Lab-Kit/Reference/ONBOARDING.md):
#   10.10.10.0/24 — LabInternal switch (VM↔VM management)
#   10.10.20.0/24 — External switch    (host↔physical laptop)

[lab_servers]
dc01       ansible_host=10.10.10.10
member01   ansible_host=10.10.10.11

[lab_workstations]
ws01       ansible_host=10.10.10.20
wo02       ansible_host=10.10.20.30   # physical laptop on External subnet

[lab:children]
lab_servers
lab_workstations

[lab:vars]
ansible_user=Administrator
ansible_password=YOUR_ADMIN_PASSWORD_HERE
ansible_connection=winrm
ansible_winrm_transport=basic
ansible_winrm_port=5985
ansible_winrm_scheme=http
# For production — use HTTPS and certificate validation:
# ansible_winrm_transport=kerberos
# ansible_winrm_scheme=https
# ansible_winrm_port=5986
# ansible_winrm_server_cert_validation=validate
